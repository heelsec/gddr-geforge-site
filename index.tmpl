      {% for topic, faqs in faq_groups.values() %}
      {% set j = loop.index0 %}
      {% if topic != "" %}
      <h4 style="padding-top: 20px;">{{topic}}</h4>
      {% endif %}

      {% for q in faqs %}
      {% set i = loop.index0 %}
      <div id="accordion">
        <div class="card">
          <div id="question-{{j}}-{{i}}">
            <h6>
              <button class="btn btn-link collapsed text-start collapse-toggle" data-bs-toggle="collapse" data-bs-target="#answer-{{j}}-{{i}}"
                aria-expanded="true" aria-controls="answer-{{j}}-{{i}}">
                {{q[0] | indent(width=16)}}
              </button>
            </h6>
          </div>
          <div id="answer-{{j}}-{{i}}" class="collapse" aria-labelledby="question-{{j}}-{{i}}">
            <div class="card-body">
              <p>
                {{q[1] | indent(width=16)}}
              </p>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
      {% endfor %}
